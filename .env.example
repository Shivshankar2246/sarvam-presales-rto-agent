# --- Sarvam AI ---
# Get a key (₹100 free credits) at https://dashboard.sarvam.ai
# Leave blank to run the repo in offline MOCK mode (scripted demo, no network).
SARVAM_API_KEY=

# Model overrides (optional — defaults shown). sarvam-m is DEPRECATED, don't use it.
SARVAM_CHAT_MODEL=sarvam-30b        # or sarvam-105b
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TRANSLATE_MODEL=mayura:v1

# --- n8n agentic backend ---
# The webhook the agent's tools POST to (OMS / 3PL / WhatsApp / CRM fan-out).
# Leave blank and tool calls are simulated/logged (repo still runs end-to-end).
N8N_WEBHOOK_URL=

# Force mock even when a key is present (handy for offline demos / CI).
USE_MOCK=
